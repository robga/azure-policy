{
  "properties": {
    "displayName": "Function app slots should be injected into a virtual network",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "Injecting Function Apps in a virtual network unlocks advanced networking and security features and provides you with greater control over your network security configuration. Learn more at: https://learn.microsoft.com/azure/app-service/web-sites-integrate-with-vnet.",
    "metadata": {
      "version": "1.0.0",
      "category": "App Service"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "string",
        "defaultValue": "Audit",
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        }
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/slots"
          },
          {
            "field": "kind",
            "contains": "functionapp"
          },
          {
            "field": "kind",
            "notContains": "workflowapp"
          },
          {
            "field": "kind",
            "notContains": "azurecontainerapps"
          },
          {
            "field": "Microsoft.Web/sites/slots/sku",
            "notEquals": "Dynamic"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/slots/virtualNetworkSubnetId",
                "exists": false
              },
              {
                "field": "Microsoft.Web/sites/slots/virtualNetworkSubnetId",
                "equals": ""
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/3e90a76f-8f87-4753-9f18-b40f206c2653",
  "name": "3e90a76f-8f87-4753-9f18-b40f206c2653"
}