{
  "properties": {
    "displayName": "App Service app slots should be injected into a virtual network.",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. App Service app slots should be injected into a virtual network.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/slots"
          },
          {
            "field": "Microsoft.Web/sites/slots/virtualNetworkSubnetId",
            "equals": ""
          },
          {
            "field": "Microsoft.Web/sites/slots/hostingEnvironmentProfile.id",
            "exists": false
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/df42d971-b39b-43a4-a987-b29d1bfbffba",
  "name": "df42d971-b39b-43a4-a987-b29d1bfbffba"
}