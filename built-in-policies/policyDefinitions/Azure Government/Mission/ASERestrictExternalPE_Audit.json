{
  "properties": {
    "displayName": "App Service Environments in this tenant should deny link to external private endpoints",
    "policyType": "BuiltIn",
    "mode": "All",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Deny external private endpoints linked to App Service Environments in this tenant.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/hostingEnvironments/privateEndpointConnections"
          },
          {
            "field": "Microsoft.Web/hostingEnvironments/privateEndpointConnections/privateLinkServiceConnectionState.status",
            "equals": "Approved"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/hostingEnvironments/privateEndpointConnections/privateEndpoint.id",
                "exists": false
              },
              {
                "value": "[split(concat(field('Microsoft.Web/hostingEnvironments/privateEndpointConnections/privateEndpoint.id'), '//'), '/')[2]]",
                "notEquals": "[subscription().subscriptionId]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/a475e840-2781-4c79-aaf0-4047828759b1",
  "name": "a475e840-2781-4c79-aaf0-4047828759b1"
}