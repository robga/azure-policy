{
  "properties": {
    "displayName": "App Service app slots should disable public network access.",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Disable public network access for your App Services.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/slots"
          },
          {
            "exists": "false",
            "field": "Microsoft.Web/sites/slots/hostingEnvironmentProfile.id"
          },
          {
            "field": "Microsoft.Web/sites/slots/publicNetworkAccess",
            "equals": "Enabled"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/slots/siteConfig.ipSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              },
              {
                "field": "Microsoft.Web/sites/slots/siteConfig.scmIpSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/0e3ccb86-ad68-43a5-8cd0-42035638b199",
  "name": "0e3ccb86-ad68-43a5-8cd0-42035638b199"
}