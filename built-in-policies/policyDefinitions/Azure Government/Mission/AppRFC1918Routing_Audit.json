{
  "properties": {
    "displayName": "App Service apps should enable outbound non-RFC 1918 traffic to Azure Virtual Network.",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. App Service apps should enable outbound non-RFC 1918 traffic to Azure Virtual Network.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Web/sites"
              },
              {
                "exists": "false",
                "field": "Microsoft.Web/sites/hostingEnvironmentProfile.id"
              },
              {
                "field": "Microsoft.Web/sites/vnetRouteAllEnabled",
                "equals": "false"
              }
            ]
          },
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Web/sites/config"
              },
              {
                "field": "Microsoft.Web/sites/config/vnetRouteAllEnabled",
                "equals": "false"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/73aa9838-1906-4490-aa32-f7b89a8f4554",
  "name": "73aa9838-1906-4490-aa32-f7b89a8f4554"
}