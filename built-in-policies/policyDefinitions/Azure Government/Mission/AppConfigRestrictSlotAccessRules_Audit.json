{
  "properties": {
    "displayName": "Restrict Slot Configuration Access Rules",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Restrict Slot Configuration Access Rules to Specified Sources.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "allowedServiceTags": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service Tags",
          "description": "List of allowed Service Tags."
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/slots/config"
          },
          {
            "anyOf": [
              {
                "count": {
                  "field": "Microsoft.Web/sites/slots/config/ipSecurityRestrictions[*]",
                  "where": {
                    "not": {
                      "anyOf": [
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/ipSecurityRestrictions[*].tag')]",
                              "equals": "ServiceTag"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/ipSecurityRestrictions[*].ipAddress')]",
                              "in": "[parameters('allowedServiceTags')]"
                            }
                          ]
                        },
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/ipSecurityRestrictions[*].Action')]",
                              "equals": "Deny"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/ipSecurityRestrictions[*].ipAddress')]",
                              "equals": "Any"
                            }
                          ]
                        }
                      ]
                    }
                  }
                },
                "greater": 0
              },
              {
                "count": {
                  "field": "Microsoft.Web/sites/slots/config/scmIpSecurityRestrictions[*]",
                  "where": {
                    "not": {
                      "anyOf": [
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/scmIpSecurityRestrictions[*].tag')]",
                              "equals": "ServiceTag"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/scmIpSecurityRestrictions[*].ipAddress')]",
                              "in": "[parameters('allowedServiceTags')]"
                            }
                          ]
                        },
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/scmIpSecurityRestrictions[*].Action')]",
                              "equals": "Deny"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/slots/config/scmIpSecurityRestrictions[*].ipAddress')]",
                              "equals": "Any"
                            }
                          ]
                        }
                      ]
                    }
                  }
                },
                "greater": 0
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/f9fd212a-5a3c-4754-a9af-560ec3b1ae13",
  "name": "f9fd212a-5a3c-4754-a9af-560ec3b1ae13"
}