{
  "properties": {
    "displayName": "App Service app configs should restrict default network access in Mission Platform products and services",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Configure App Service App Configs to restrict default network access by setting IP Security Restrictions Default Action and SCM IP Security Restrictions Default Action to Deny.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/config"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/config/ipSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              },
              {
                "field": "Microsoft.Web/sites/config/scmIpSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/b546c248-6dee-41e6-82f7-978634aeb73d",
  "name": "b546c248-6dee-41e6-82f7-978634aeb73d"
}