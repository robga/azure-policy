{
  "properties": {
    "displayName": "App Service apps should disable public network access.",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Disable public network access for your App Services so that it is not accessible over the public internet. This can reduce data leakage risks. Learn more at: https://aka.ms/app-service-private-endpoint.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "exists": "false",
            "field": "Microsoft.Web/sites/hostingEnvironmentProfile.id"
          },
          {
            "field": "Microsoft.Web/sites/publicNetworkAccess",
            "equals": "Enabled"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/siteConfig.ipSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              },
              {
                "field": "Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictionsDefaultAction",
                "equals": "Allow"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/b0779e02-7159-4057-bcbf-bd6132847d2b",
  "name": "b0779e02-7159-4057-bcbf-bd6132847d2b"
}