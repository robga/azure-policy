{
  "properties": {
    "displayName": "App Service apps should enable configuration routing to Azure Virtual Network.",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. App Service apps should enable configuration routing to Azure Virtual Network.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "exists": "false",
            "field": "Microsoft.Web/sites/hostingEnvironmentProfile.id"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/vnetImagePullEnabled",
                "notEquals": true
              },
              {
                "field": "Microsoft.Web/sites/vnetContentShareEnabled",
                "notEquals": true
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/86b1d4f9-358c-407c-9bb0-52bf287b222f",
  "name": "86b1d4f9-358c-407c-9bb0-52bf287b222f"
}