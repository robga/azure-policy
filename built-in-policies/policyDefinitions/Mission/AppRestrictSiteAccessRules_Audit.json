{
  "properties": {
    "displayName": "App Service apps should restrict site access rules to specified sources in Mission Platform products and services",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Restrict Site Access Rules to Specified Sources.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "allowedServiceTags": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Service Tags",
          "description": " List of allowed Service Tags."
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "anyOf": [
              {
                "count": {
                  "field": "Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*]",
                  "where": {
                    "not": {
                      "anyOf": [
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*].tag')]",
                              "equals": "ServiceTag"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*].ipAddress')]",
                              "in": "[parameters('allowedServiceTags')]"
                            }
                          ]
                        },
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*].Action')]",
                              "equals": "Deny"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*].ipAddress')]",
                              "equals": "Any"
                            }
                          ]
                        }
                      ]
                    }
                  }
                },
                "greater": 0
              },
              {
                "count": {
                  "field": "Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictions[*]",
                  "where": {
                    "not": {
                      "anyOf": [
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictions[*].tag')]",
                              "equals": "ServiceTag"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictions[*].ipAddress')]",
                              "in": "[parameters('allowedServiceTags')]"
                            }
                          ]
                        },
                        {
                          "allOf": [
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictions[*].Action')]",
                              "equals": "Deny"
                            },
                            {
                              "value": "[current('Microsoft.Web/sites/siteConfig.scmIpSecurityRestrictions[*].ipAddress')]",
                              "equals": "Any"
                            }
                          ]
                        }
                      ]
                    }
                  }
                },
                "greater": 0
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/f36fcc62-6b1b-46e3-9a94-97af3eb4a55e",
  "name": "f36fcc62-6b1b-46e3-9a94-97af3eb4a55e"
}