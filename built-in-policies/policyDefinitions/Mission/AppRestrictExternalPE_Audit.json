{
  "properties": {
    "displayName": "App network configuration should deny link to external private endpoints",
    "policyType": "BuiltIn",
    "mode": "Indexed",
    "description": "This policy applies exclusively to Mission Platform products and services; usage outside of these scopes is not supported. Deny external private endpoints linked to apps in this tenant.",
    "metadata": {
      "version": "1.0.0",
      "category": "Mission"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/privateEndpointConnections"
          },
          {
            "field": "Microsoft.Web/sites/privateEndpointConnections/privateLinkServiceConnectionState.status",
            "equals": "Approved"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/privateEndpointConnections/privateEndpoint.id",
                "exists": false
              },
              {
                "value": "[split(concat(field('Microsoft.Web/sites/privateEndpointConnections/privateEndpoint.id'), '//'), '/')[2]]",
                "notEquals": "[subscription().subscriptionId]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/Microsoft.Authorization/policyDefinitions/a83269e2-b4f7-4a3f-b5ed-897c787cbc7c",
  "name": "a83269e2-b4f7-4a3f-b5ed-897c787cbc7c"
}